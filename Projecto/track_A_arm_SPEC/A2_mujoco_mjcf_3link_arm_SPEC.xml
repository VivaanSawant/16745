<?xml version="1.0" encoding="utf-8"?>
<!--
  A2_mujoco_mjcf_3link_arm_SPEC.xml
  =================================
  **PDF section:** Track A — A2 (MJCF / MuJoCo model file)

  **What this file is:** MuJoCo XML for the **3-link planar throwing arm** + a **release_site**
  at the fingertip. Axes follow **PDF world convention**: x toward board, y horizontal left, z up.

  **What this file is NOT:** It does not include the dart as a dynamic body after release; release
  state is read from `release_site` and passed to **Track B** Python projectile (**C1**).

  **PDF A2 checklist (see also README_TRACK_MAPPING_CMU16745.md):**
  - worldbody → shoulder_mount (fixed) → upper_arm (hinge) → forearm (hinge) → hand (hinge) → site
  - timestep 0.001 s
  - three `<motor>` actuators with ctrlrange = torque limits
  - `<key>` cocked posture: shoulder -55°, elbow -90°, wrist -20°

  **Load in Python:** `mujoco.MjModel.from_xml_path(...)` (requires `mujoco` package).
-->
<mujoco model="dart_robot_3link_planar_SPEC">
  <compiler angle="degree" inertiafromgeom="true"/>

  <option timestep="0.001" gravity="0 0 -9.81"/>

  <default>
    <joint limited="true" damping="0.1"/>
    <geom type="capsule" condim="1" friction="0.6 0.005 0.0001"/>
  </default>

  <asset/>

  <worldbody>
    <!-- Fixed mount at oche (PDF A1): shoulder (0,0,1.50) -->
    <body name="shoulder_mount" pos="0 0 1.50">
      <site name="shoulder_origin" pos="0 0 0" size="0.01"/>
      <!-- Upper arm: hinge about **y** = sagittal plane (x-z motion) -->
      <body name="upper_arm" pos="0 0 0">
        <joint name="shoulder" type="hinge" axis="0 1 0" range="-60 180"/>
        <geom name="upper_arm_geom" fromto="0 0 0 0.30 0 0" size="0.02" mass="2.1"/>
        <body name="forearm" pos="0.30 0 0">
          <joint name="elbow" type="hinge" axis="0 1 0" range="-145 0"/>
          <geom name="forearm_geom" fromto="0 0 0 0.26 0 0" size="0.018" mass="1.2"/>
          <body name="hand" pos="0.26 0 0">
            <joint name="wrist" type="hinge" axis="0 1 0" range="-70 70"/>
            <geom name="hand_geom" fromto="0 0 0 0.08 0 0" size="0.015" mass="0.4"/>
            <!-- Dart release point at fingertip (PDF A2) -->
            <site name="release_site" pos="0.08 0 0" size="0.005" rgba="1 0 0 0.5"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <!-- PDF A2: shoulder ±100, elbow ±70, wrist ±20 Nm -->
    <motor name="tau_shoulder" joint="shoulder" gear="1" ctrllimited="true" ctrlrange="-100 100"/>
    <motor name="tau_elbow" joint="elbow" gear="1" ctrllimited="true" ctrlrange="-70 70"/>
    <motor name="tau_wrist" joint="wrist" gear="1" ctrllimited="true" ctrlrange="-20 20"/>
  </actuator>

  <!-- PDF A2 keyframe: cocked arm (degrees in MJCF because compiler angle=degree on bodies... key uses qpos in radians by default - MuJoCo key qpos is radians) -->
  <keyframe>
    <key name="cocked" qpos="-0.9599 -1.5708 -0.3491"/>
    <!-- -55°, -90°, -20° — overhand posture: shoulder raised, forearm above elbow (no downward past-parallel) -->
  </keyframe>
</mujoco>
